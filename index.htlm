<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tu viens manger avec moi ? 🥂</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap');

    body {
      margin: 0;
      padding: 0;
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #f5e6d3, #e8d5c0);
      color: #5c4634;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .container {
      text-align: center;
      max-width: 420px;
      padding: 30px 20px;
      background: rgba(255, 248, 240, 0.95);
      border-radius: 25px;
      box-shadow: 0 15px 35px rgba(140, 110, 80, 0.2);
      border: 3px solid #d4b89f;
    }

    h1 {
      color: #8c6f5c;
      font-size: 1.8rem;
      margin-bottom: 20px;
    }

    .question {
      font-size: 1.4rem;
      margin: 25px 0;
      line-height: 1.3;
    }

    .btn {
      padding: 15px 35px;
      margin: 12px;
      font-size: 1.2rem;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.4s ease;
      font-weight: 600;
    }

    .yes {
      background: #c8a8a0;
      color: white;
    }

    .no {
      background: #d4b89f;
      color: #5c4634;
      position: relative;
    }

    .yes:hover { background: #b58f85; transform: scale(1.08); }
    
    .result {
      margin-top: 30px;
      font-size: 1.3rem;
      min-height: 80px;
    }

    .hidden { display: none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>💌 Invitation Spéciale</h1>

    <!-- Page 1 -->
    <div id="page1">
      <p class="question">Es-tu présent·e le <strong>04/07/2026</strong> pour un restau au soir ?</p>
      <button class="btn yes" onclick="answerYes()">Oui, avec plaisir !</button>
      <button class="btn no" id="noBtn" onclick="fleeNo()">Non...</button>
    </div>

    <!-- Page 2 : Avec qui ? -->
    <div id="page2" class="hidden">
      <p class="question">Super ! Tu viens comment ?</p>
      <button class="btn yes" onclick="goToPage3('seul')">Seul·e</button>
      <button class="btn yes" onclick="goToPage3('plus1')">Avec mon +1 ❤️</button>
    </div>

    <!-- Page 3 : Distance -->
    <div id="page3" class="hidden">
      <p class="question" id="distanceQuestion">Tu préfères un resto proche de Lille ou tu es OK pour 30-40 min de route ?</p>
      <button class="btn yes" onclick="finalYes('Lille')">Proche de Lille</button>
      <button class="btn yes" onclick="finalYes('Route')">OK pour 30-40 min</button>
    </div>

    <!-- Merci final -->
    <div id="final" class="hidden">
      <p class="result" style="font-size:2rem;">❤️ Merci beaucoup !</p>
      <p id="finalText" style="margin-top:20px;"></p>
    </div>
  </div>

  <script>
    let attempts = 0;
    const noBtn = document.getElementById('noBtn');

    function fleeNo() {
      attempts++;
      noBtn.style.transition = "all 0.6s ease";
      
      if (attempts === 1) {
        noBtn.textContent = "Tu es sûr(e) ?";
        noBtn.style.transform = "translateX(-80px)";
        setTimeout(() => noBtn.style.transform = "translateX(80px)", 150);
      } else if (attempts === 2) {
        noBtn.textContent = "Tu vas me manquer 😢";
        noBtn.style.transform = "translateX(-120px)";
        setTimeout(() => noBtn.style.transform = "translateX(120px)", 150);
      } else {
        // Dernier clic accepté
        document.getElementById('page1').classList.add('hidden');
        document.getElementById('final').classList.remove('hidden');
        document.getElementById('finalText').innerHTML = "Merci pour ta réponse...<br>Tu vas vraiment me manquer 💔";
      }
    }

    function answerYes() {
      document.getElementById('page1').classList.add('hidden');
      document.getElementById('page2').classList.remove('hidden');
    }

    function goToPage3(type) {
      document.getElementById('page2').classList.add('hidden');
      document.getElementById('page3').classList.remove('hidden');
      
      if (type === 'plus1') {
        document.getElementById('distanceQuestion').innerHTML = "Et avec ton +1, tu préfères un resto proche de Lille ou tu es OK pour 30-40 min de route ?";
      }
    }

    function finalYes(choice) {
      document.getElementById('page3').classList.add('hidden');
      document.getElementById('final').classList.remove('hidden');
      
      const text = choice === 'Lille' 
        ? "Parfait ! Je te propose un super spot près de Lille ❤️<br>On se tient au courant pour la réservation !"
        : "Super, j’ai plein d’idées un peu plus loin aussi ! On va trouver un endroit magique.";
      
      document.getElementById('finalText').innerHTML = text;
    }
  </script>
</body>
</html>
